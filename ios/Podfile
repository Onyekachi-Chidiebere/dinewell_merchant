# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'DineWellMerchant' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_configuration|
        build_configuration.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
        build_configuration.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'

        # Xcode 26: fmt 11.x fails consteval checks in Apple Clang.
        if target.name == 'fmt'
          build_configuration.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
      end
    end

    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26: disable fmt consteval (RN 0.79 ships fmt 11.0.2).
    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      unless content.include?('Xcode 26 workaround')
        patched = content.gsub(
          /(#elif defined\(__cpp_consteval\)\n# {1,2}define FMT_USE_CONSTEVAL) 1/,
          "// Xcode 26 workaround: disable consteval\n\\1 0"
        )
        if patched != content
          File.chmod(0644, fmt_base)
          File.write(fmt_base, patched)
          Pod::UI.puts 'Patched fmt for Xcode 26'.green
        end
      end
    end

    # Xcode 26: StripeSdk.mm fails due to STPPaymentStatus enum mismatch (stripe-react-native < 0.61).
    stripe_interop = File.expand_path('../node_modules/@stripe/stripe-react-native/ios/StripeSwiftInterop.h', __dir__)
    if File.exist?(stripe_interop)
      content = File.read(stripe_interop)
      unless content.include?('Xcode 26 workaround')
        patched = content.gsub(
          'typedef NS_ENUM(NSUInteger, STPPaymentStatus);',
          "// Xcode 26 workaround\ntypedef NS_ENUM(NSInteger, STPPaymentStatus);"
        )
        if patched != content
          File.chmod(0644, stripe_interop)
          File.write(stripe_interop, patched)
          Pod::UI.puts 'Patched StripeSwiftInterop.h for Xcode 26'.green
        end
      end
    end
  end
end
